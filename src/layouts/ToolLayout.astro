---
import Layout from './Layout.astro';
import { tools } from '../data/tools';

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const tool = tools.find((t) => t.slug === slug);

const SITE_URL = 'https://tinytask.tools';
const toolUrl = `${SITE_URL}/tools/${slug}`;

const webAppSchema = tool
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebApplication',
      name: tool.name,
      url: toolUrl,
      description: tool.metaDescription ?? tool.description,
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Any',
      browserRequirements: 'Requires JavaScript. Runs entirely in-browser.',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
    }
  : null;

const breadcrumbSchema = tool
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: SITE_URL,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: tool.name,
          item: toolUrl,
        },
      ],
    }
  : null;

const faqSchema =
  tool?.faq && tool.faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: tool.faq.map((entry) => ({
          '@type': 'Question',
          name: entry.q,
          acceptedAnswer: {
            '@type': 'Answer',
            text: entry.a,
          },
        })),
      }
    : null;
---

<Layout
  title={tool?.name}
  description={tool?.metaDescription ?? tool?.description}
  image={tool ? `/og/${tool.slug}.png` : undefined}
>
  {/* eslint-disable astro/no-set-html-directive */}
  {webAppSchema && <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />}
  {
    breadcrumbSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )
  }
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  {/* eslint-enable astro/no-set-html-directive */}

  <script define:vars={{ slug }}>
    navigator.sendBeacon?.('/api/hit?tool=' + slug);
  </script>
  <div class="tool-page">
    <nav class="tool-nav">
      <a href="/" class="back-link">← tt_</a>
    </nav>

    <header class="tool-header">
      <h1 class="tool-title">{tool?.name}</h1>
      {tool?.description && <p class="tool-desc">{tool.description}</p>}
    </header>

    <div class="tool-body">
      <slot />
    </div>

    {
      tool?.faq && tool.faq.length > 0 && (
        <section class="tool-faq" aria-label="Frequently asked questions">
          <h2 class="faq-heading">FAQ</h2>
          {tool.faq.map((entry) => (
            <details class="faq-item">
              <summary class="faq-question">{entry.q}</summary>
              <p class="faq-answer">{entry.a}</p>
            </details>
          ))}
        </section>
      )
    }
  </div>
</Layout>

<style>
  .tool-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    max-width: 960px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .tool-nav {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .back-link {
    font-size: 0.75rem;
    color: var(--fg-dim);
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .back-link:hover {
    color: var(--fg);
  }

  .tool-header {
    padding: 2rem 0 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .tool-title {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--fg);
  }

  .tool-desc {
    margin: 0;
    font-size: 0.8rem;
    color: var(--fg-dim);
    line-height: 1.5;
  }

  .tool-body {
    flex: 1;
    padding: 2rem 0;
  }

  /* FAQ section */
  .tool-faq {
    border-top: 1px solid var(--border);
    padding: 2rem 0 3rem;
  }

  .faq-heading {
    margin: 0 0 1.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }

  .faq-item {
    border-bottom: 1px solid var(--border);
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.875rem 0;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--fg);
    cursor: pointer;
    list-style: none;
    gap: 1rem;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::after {
    content: '+';
    font-size: 1rem;
    color: var(--fg-dim);
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }

  .faq-item[open] .faq-question::after {
    content: '−';
  }

  .faq-answer {
    margin: 0;
    padding: 0 0 1rem;
    font-size: 0.8rem;
    color: var(--fg-dim);
    line-height: 1.6;
  }
</style>
