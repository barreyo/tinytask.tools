---
import Layout from '../layouts/Layout.astro';
import ToolCard from '../components/ToolCard.astro';
import ToolSearch from '../components/ToolSearch.astro';
import { tools } from '../data/tools';
import popularity from '../data/tool-popularity.json';

const hits = popularity as Record<string, number>;
const sortedTools = [...tools].sort((a, b) => {
  const aHits = hits[a.slug] ?? 0;
  const bHits = hits[b.slug] ?? 0;
  if (bHits !== aHits) return bHits - aHits;
  // Preserve original order for ties (including both at 0)
  return tools.indexOf(a) - tools.indexOf(b);
});

const SITE_URL = 'https://tinytask.tools';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'tinytask.tools',
  url: SITE_URL,
  description:
    'Free browser-only developer tools. No sign-ups, no tracking — everything runs in your browser.',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE_URL}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'tinytask.tools — Developer Utilities',
  description: 'A collection of free, browser-only developer utilities.',
  url: SITE_URL,
  itemListElement: tools
    .filter((t) => t.implemented)
    .map((t, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: t.name,
      description: t.description,
      url: `${SITE_URL}/tools/${t.slug}`,
    })),
};
---

<Layout
  title="Free Online Developer Utilities"
  description="Free browser-only developer tools: UUID generator, JSON formatter, Base64 encoder, hash generator, JWT debugger, and more. No sign-ups, no tracking — everything runs in your browser."
>
  {/* eslint-disable astro/no-set-html-directive */}
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  {/* eslint-enable astro/no-set-html-directive */}
  <div class="page">
    <header class="site-header">
      <button class="search-corner-btn" id="search-corner-btn" aria-label="Search tools">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.25"></circle>
          <line
            x1="9.5"
            y1="9.5"
            x2="13"
            y2="13"
            stroke="currentColor"
            stroke-width="1.25"
            stroke-linecap="square"></line>
        </svg>
      </button>
      <h1 class="site-heading">
        <div class="site-logo" aria-label="tinytask.tools">
          <span class="logo-tt">tt</span><span class="logo-cursor" aria-hidden="true">_</span>
        </div>
        <span class="site-name">tinytask.tools</span>
      </h1>
      <span class="site-tagline">small browser-only utilities</span>
      <button class="search-trigger" id="search-trigger" aria-label="Search tools (⌘F)">
        <span class="search-trigger-prompt">&gt;</span>
        <span class="search-trigger-label">find a tool…</span>
        <kbd class="search-trigger-hint">⌘F</kbd>
      </button>
    </header>

    <div class="tool-grid">
      {sortedTools.map((tool) => <ToolCard tool={tool} />)}
    </div>

    <footer class="site-footer">
      <p>
        Missing a tool? <a
          href="https://github.com/barreyo/tinytask.tools/issues"
          target="_blank"
          rel="noopener noreferrer">Request one</a
        > or <a
          href="https://github.com/barreyo/tinytask.tools"
          target="_blank"
          rel="noopener noreferrer">contribute on GitHub</a
        >.
      </p>
    </footer>
  </div>

  <ToolSearch totalCount={tools.length} />
</Layout>

<script>
  // ── Search trigger buttons ────────────────────────────────────────────────
  // Re-runs on every Astro page navigation via astro:page-load
  function initSearchTrigger() {
    const trigger = document.getElementById('search-trigger');
    const cornerBtn = document.getElementById('search-corner-btn');
    const hint = trigger?.querySelector('.search-trigger-hint');

    if (hint && !/mac/i.test(navigator.platform)) {
      hint.textContent = 'Ctrl+F';
    }

    function openPanel() {
      document.getElementById('search-panel')?.classList.add('is-open');
      document.getElementById('search-backdrop')?.classList.add('is-open');
      document.getElementById('search-panel')?.setAttribute('aria-hidden', 'false');
      document.getElementById('tool-search')?.focus();
    }

    // Clone nodes to remove any stale listeners from a previous navigation
    trigger?.replaceWith(trigger.cloneNode(true));
    cornerBtn?.replaceWith(cornerBtn.cloneNode(true));
    document.getElementById('search-trigger')?.addEventListener('click', openPanel);
    document.getElementById('search-corner-btn')?.addEventListener('click', openPanel);
  }

  document.addEventListener('astro:page-load', initSearchTrigger);
</script>

<script>
  // ── Vimium-style hint navigation ──────────────────────────────────────────
  const HINT_KEYS = 'asdfghjklqwertyuiopzxcvbnm'.split('');
  let hintMode = false;
  let hintGrid: HTMLElement | null = null;

  function activateHints() {
    if (hintMode || !hintGrid) return;
    if (document.getElementById('search-panel')?.classList.contains('is-open')) return;

    hintMode = true;
    document.body.setAttribute('data-hint-mode', '');

    (
      Array.from(
        hintGrid.querySelectorAll('.tool-card-wrapper:not([data-hidden])'),
      ) as HTMLElement[]
    ).forEach((wrapper, i) => {
      const key = HINT_KEYS[i];
      if (!key) return;
      wrapper.dataset.hintKey = key;
      const badge = document.createElement('span');
      badge.className = 'vimium-hint';
      badge.textContent = key.toUpperCase();
      wrapper.querySelector('.tool-card')?.appendChild(badge);
    });
  }

  function deactivateHints() {
    if (!hintMode) return;
    hintMode = false;
    document.body.removeAttribute('data-hint-mode');
    document.querySelectorAll('.vimium-hint').forEach((el) => el.remove());
    if (hintGrid) {
      (
        Array.from(hintGrid.querySelectorAll('.tool-card-wrapper[data-hint-key]')) as HTMLElement[]
      ).forEach((w) => {
        delete w.dataset.hintKey;
      });
    }
  }

  function handleHintKeydown(e: KeyboardEvent) {
    const active = document.activeElement as HTMLElement | null;
    const isTyping =
      active &&
      (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.isContentEditable);

    if (e.key === 'f' && !isTyping && !e.metaKey && !e.ctrlKey && !e.altKey) {
      e.preventDefault();
      activateHints();
      return;
    }

    if (!hintMode) return;

    if (e.key === 'Escape') {
      e.preventDefault();
      deactivateHints();
      return;
    }

    const key = e.key.toLowerCase();
    if (/^[a-z]$/.test(key)) {
      e.preventDefault();
      const wrapper = hintGrid?.querySelector(`.tool-card-wrapper[data-hint-key="${key}"]`);
      if (wrapper) {
        const link = wrapper.querySelector('a') as HTMLAnchorElement | null;
        deactivateHints();
        link?.click();
      } else {
        deactivateHints();
      }
    }
  }

  function initHints() {
    // Reset state and re-point grid reference to the freshly rendered DOM
    deactivateHints();
    hintGrid = document.querySelector('.tool-grid');

    // Remove stale listener then re-add — prevents duplicates across navigations
    document.removeEventListener('keydown', handleHintKeydown);
    if (hintGrid) {
      document.addEventListener('keydown', handleHintKeydown);
    }
  }

  document.addEventListener('astro:page-load', initHints);
</script>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .site-header {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .search-corner-btn {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--fg-dim);
    cursor: pointer;
    transition:
      border-color 0.1s,
      color 0.1s;
  }

  .search-corner-btn:hover {
    border-color: var(--border-active);
    color: var(--fg);
  }

  .site-heading {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .site-logo {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--fg);
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .logo-tt {
    color: var(--fg);
  }

  .logo-cursor {
    color: var(--fg);
  }

  @media (prefers-reduced-motion: no-preference) {
    .logo-cursor {
      animation: cursor-blink 1s step-start infinite;
    }
  }

  @keyframes cursor-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .site-name {
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--fg-dim);
  }

  .site-tagline {
    font-size: 0.75rem;
    color: var(--fg-dim);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .search-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    padding: 0.5rem 0.75rem;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--fg-dim);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    cursor: pointer;
    width: 100%;
    max-width: 320px;
    transition:
      border-color 0.1s,
      color 0.1s;
    text-align: left;
  }

  .search-trigger:hover {
    border-color: var(--border-active);
    color: var(--fg);
  }

  .search-trigger-prompt {
    flex-shrink: 0;
  }

  .search-trigger-label {
    flex: 1;
    opacity: 0.5;
  }

  .search-trigger-hint {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--fg-dim);
    border: 1px solid var(--border);
    padding: 0.1rem 0.3rem;
    line-height: 1.4;
    background: transparent;
    flex-shrink: 0;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    position: relative;
  }

  .site-footer {
    margin-top: auto;
    padding: 2rem;
    text-align: center;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--fg-dim);
  }

  .site-footer a {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .site-footer a:hover {
    color: var(--accent, var(--fg));
  }
</style>
