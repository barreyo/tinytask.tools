---
import Layout from '../layouts/Layout.astro';
import ToolCard from '../components/ToolCard.astro';
import ToolSearch from '../components/ToolSearch.astro';
import { tools } from '../data/tools';
import popularity from '../data/tool-popularity.json';
import { getPrideColor } from '../utils/pride';

const hits = popularity as Record<string, number>;
const sortedTools = [...tools].sort((a, b) => {
  const aHits = hits[a.slug] ?? 0;
  const bHits = hits[b.slug] ?? 0;
  if (bHits !== aHits) return bHits - aHits;
  // Preserve original order for ties (including both at 0)
  return tools.indexOf(a) - tools.indexOf(b);
});

const now = new Date();

const SITE_URL = 'https://tinytask.tools';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'tinytask.tools',
  url: SITE_URL,
  description:
    'Free browser-only developer tools. No sign-ups, no tracking — everything runs in your browser.',
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE_URL}/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'tinytask.tools — Developer Utilities',
  description: 'A collection of free, browser-only developer utilities.',
  url: SITE_URL,
  itemListElement: tools
    .filter((t) => t.implemented)
    .map((t, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: t.name,
      description: t.description,
      url: `${SITE_URL}/tools/${t.slug}`,
    })),
};
---

<Layout
  title="Free Online Developer Utilities"
  description="Free browser-only developer tools: UUID generator, JSON formatter, Base64 encoder, hash generator, JWT debugger, and more. No sign-ups, no tracking — everything runs in your browser."
>
  {/* eslint-disable astro/no-set-html-directive */}
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  {/* eslint-enable astro/no-set-html-directive */}
  <div class="page">
    <header class="site-header">
      <button class="search-corner-btn" id="search-corner-btn" aria-label="Search tools">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.25"></circle>
          <line
            x1="9.5"
            y1="9.5"
            x2="13"
            y2="13"
            stroke="currentColor"
            stroke-width="1.25"
            stroke-linecap="square"></line>
        </svg>
      </button>
      <h1 class="site-heading">
        <div class="site-logo" aria-label="tinytask.tools">
          <span class="logo-tt"
            ><span class="logo-t-first"
              >t<svg
                class="santa-hat"
                viewBox="0 0 18 16"
                width="18"
                height="16"
                aria-hidden="true"
                focusable="false"
              >
                <polygon points="9,1 17,12 1,12" fill="#cc2222"></polygon>
                <rect x="0" y="11" width="18" height="4.5" rx="2.25" fill="#efefef"></rect>
                <circle cx="9" cy="2.5" r="2.5" fill="#efefef"></circle>
              </svg></span
            >t</span
          ><span class="logo-cursor" aria-hidden="true">_</span>
        </div>
        <span class="site-name">tinytask.tools</span>
      </h1>
      <span class="site-tagline">small browser-only utilities</span>
      <button class="search-trigger" id="search-trigger" aria-label="Search tools (⌘F)">
        <span class="search-trigger-prompt">&gt;</span>
        <span class="search-trigger-label">find a tool…</span>
        <kbd class="search-trigger-hint"><span class="mod">⌘</span><span class="sep">+</span>F</kbd>
      </button>
    </header>

    <div class="tool-grid">
      {sortedTools.map((tool, i) => <ToolCard tool={tool} prideColor={getPrideColor(i, now)} />)}
    </div>

    <footer class="site-footer">
      <p>
        Missing a tool? <a
          href="https://github.com/barreyo/tinytask.tools/issues"
          target="_blank"
          rel="noopener noreferrer">Request one</a
        > or <a
          href="https://github.com/barreyo/tinytask.tools"
          target="_blank"
          rel="noopener noreferrer">contribute on GitHub</a
        >.
      </p>
      <ul class="keybindings" aria-label="Keyboard shortcuts">
        <li>
          <kbd id="kb-search"><span class="mod">⌘</span><span class="sep">+</span>F</kbd> search
        </li>
        <li><kbd>f</kbd> hint mode</li>
        <li><kbd>↵</kbd> open result</li>
        <li><kbd>esc</kbd> close</li>
      </ul>
    </footer>
  </div>

  <ToolSearch totalCount={tools.length} />
</Layout>

<script>
  // ── Platform-aware keybinding label ──────────────────────────────────────
  (function patchSearchKbd() {
    const isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform);
    if (!isMac) {
      const kbd = document.getElementById('kb-search');
      if (kbd) kbd.innerHTML = '<span class="mod">Ctrl</span><span class="sep">+</span>F';
    }
  })();
</script>

<script>
  // ── Search trigger buttons ────────────────────────────────────────────────
  // Re-runs on every Astro page navigation via astro:page-load
  function initSearchTrigger() {
    const trigger = document.getElementById('search-trigger');
    const cornerBtn = document.getElementById('search-corner-btn');
    const hint = trigger?.querySelector('.search-trigger-hint');

    if (hint && !/mac/i.test(navigator.platform)) {
      hint.innerHTML = '<span class="mod">Ctrl</span><span class="sep">+</span>F';
    }

    function openPanel() {
      document.getElementById('search-panel')?.classList.add('is-open');
      document.getElementById('search-backdrop')?.classList.add('is-open');
      document.getElementById('search-panel')?.setAttribute('aria-hidden', 'false');
      document.getElementById('tool-search')?.focus();
    }

    // Clone nodes to remove any stale listeners from a previous navigation
    trigger?.replaceWith(trigger.cloneNode(true));
    cornerBtn?.replaceWith(cornerBtn.cloneNode(true));
    document.getElementById('search-trigger')?.addEventListener('click', openPanel);
    document.getElementById('search-corner-btn')?.addEventListener('click', openPanel);
  }

  document.addEventListener('astro:page-load', initSearchTrigger);
</script>

<script>
  // ── Vimium-style hint navigation ──────────────────────────────────────────
  const HINT_ALPHABET = 'asdfghjklqwertyuiopzxcvbnm';

  /**
   * Generate hint labels for `count` items. Uses single-character labels when
   * count <= 26, otherwise reserves a few prefix characters for two-char
   * labels so every item gets a unique hint.
   */
  function generateHintLabels(count: number): string[] {
    const k = HINT_ALPHABET.length;
    if (count <= k) return HINT_ALPHABET.slice(0, count).split('');

    const prefixes = Math.ceil((count - k) / (k - 1));
    const labels: string[] = [];
    for (let i = prefixes; i < k && labels.length < count; i++) {
      labels.push(HINT_ALPHABET[i]);
    }
    for (let pi = 0; pi < prefixes && labels.length < count; pi++) {
      for (let si = 0; si < k && labels.length < count; si++) {
        labels.push(HINT_ALPHABET[pi] + HINT_ALPHABET[si]);
      }
    }
    return labels;
  }

  let hintMode = false;
  let hintBuffer = '';
  let hintGrid: HTMLElement | null = null;

  function activateHints() {
    if (hintMode || !hintGrid) return;
    if (document.getElementById('search-panel')?.classList.contains('is-open')) return;

    hintMode = true;
    hintBuffer = '';
    document.body.setAttribute('data-hint-mode', '');

    const wrappers = Array.from(
      hintGrid.querySelectorAll('.tool-card-wrapper:not([data-hidden])'),
    ) as HTMLElement[];
    const labels = generateHintLabels(wrappers.length);

    wrappers.forEach((wrapper, i) => {
      const label = labels[i];
      if (!label) return;
      wrapper.dataset.hintKey = label;
      const badge = document.createElement('span');
      badge.className = 'vimium-hint';
      badge.textContent = label.toUpperCase();
      wrapper.querySelector('.tool-card')?.appendChild(badge);
    });
  }

  function deactivateHints() {
    if (!hintMode) return;
    hintMode = false;
    hintBuffer = '';
    document.body.removeAttribute('data-hint-mode');
    document.querySelectorAll('.vimium-hint').forEach((el) => el.remove());
    if (hintGrid) {
      (
        Array.from(hintGrid.querySelectorAll('.tool-card-wrapper[data-hint-key]')) as HTMLElement[]
      ).forEach((w) => {
        delete w.dataset.hintKey;
      });
    }
  }

  function handleHintKeydown(e: KeyboardEvent) {
    const active = document.activeElement as HTMLElement | null;
    const isTyping =
      active &&
      (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA' || active.isContentEditable);

    if (!hintMode) {
      if (e.key === 'f' && !isTyping && !e.metaKey && !e.ctrlKey && !e.altKey) {
        e.preventDefault();
        activateHints();
      }
      return;
    }

    if (e.key === 'Escape') {
      e.preventDefault();
      deactivateHints();
      return;
    }

    if (e.key === 'Backspace') {
      e.preventDefault();
      if (hintBuffer.length > 0) {
        hintBuffer = hintBuffer.slice(0, -1);
        updateHintHighlights();
      } else {
        deactivateHints();
      }
      return;
    }

    const key = e.key.toLowerCase();
    if (!/^[a-z]$/.test(key)) return;

    e.preventDefault();
    hintBuffer += key;

    const exact = hintGrid?.querySelector(
      `.tool-card-wrapper[data-hint-key="${hintBuffer}"]`,
    ) as HTMLElement | null;
    if (exact) {
      const link = exact.querySelector('a') as HTMLAnchorElement | null;
      deactivateHints();
      link?.click();
      return;
    }

    const partials = hintGrid?.querySelectorAll(
      `.tool-card-wrapper[data-hint-key^="${hintBuffer}"]`,
    );
    if (!partials || partials.length === 0) {
      deactivateHints();
      return;
    }

    updateHintHighlights();
  }

  function updateHintHighlights() {
    if (!hintGrid) return;
    (
      Array.from(hintGrid.querySelectorAll('.tool-card-wrapper[data-hint-key]')) as HTMLElement[]
    ).forEach((w) => {
      const badge = w.querySelector('.vimium-hint') as HTMLElement | null;
      if (!badge) return;
      const matches = w.dataset.hintKey?.startsWith(hintBuffer);
      badge.classList.toggle('hint-dimmed', !matches);
    });
  }

  function initHints() {
    deactivateHints();
    hintGrid = document.querySelector('.tool-grid');

    document.removeEventListener('keydown', handleHintKeydown);
    if (hintGrid) {
      document.addEventListener('keydown', handleHintKeydown);
    }
  }

  document.addEventListener('astro:page-load', initHints);
</script>

<script>
  // ── December snow effect ───────────────────────────────────────────────────
  function initSnow() {
    const isDecember = new Date().getMonth() === 11;
    if (isDecember) document.body.classList.add('is-december');

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!isDecember || reducedMotion) return;

    const canvas = document.createElement('canvas');
    canvas.id = 'snow-canvas';
    canvas.style.cssText =
      'position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9999;opacity:0.35;';
    document.body.appendChild(canvas);

    const ctx = canvas.getContext('2d')!;

    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    const FLAKE_COUNT = 60;
    const flakes = Array.from({ length: FLAKE_COUNT }, () => ({
      x: Math.random() * window.innerWidth,
      y: Math.random() * window.innerHeight,
      r: 1 + Math.random() * 2.5,
      speed: 0.4 + Math.random() * 0.8,
      drift: (Math.random() - 0.5) * 0.3,
      opacity: 0.4 + Math.random() * 0.6,
    }));

    let raf: number;

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (const f of flakes) {
        ctx.beginPath();
        ctx.arc(f.x, f.y, f.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${f.opacity})`;
        ctx.fill();

        f.y += f.speed;
        f.x += f.drift;

        if (f.y > canvas.height + 4) {
          f.y = -4;
          f.x = Math.random() * canvas.width;
        }
        if (f.x > canvas.width + 4) f.x = -4;
        if (f.x < -4) f.x = canvas.width + 4;
      }
      raf = requestAnimationFrame(draw);
    }

    draw();

    document.addEventListener(
      'astro:before-preparation',
      () => {
        cancelAnimationFrame(raf);
        canvas.remove();
        window.removeEventListener('resize', resize);
        document.body.classList.remove('is-december');
      },
      { once: true },
    );
  }

  document.addEventListener('astro:page-load', initSnow);
</script>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .site-header {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .search-corner-btn {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--fg-dim);
    cursor: pointer;
    transition:
      border-color 0.1s,
      color 0.1s;
  }

  .search-corner-btn:hover {
    border-color: var(--border-active);
    color: var(--fg);
  }

  .site-heading {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .site-logo {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--fg);
    line-height: 1;
    margin-bottom: 0.75rem;
  }

  .logo-tt {
    color: var(--fg);
  }

  .logo-t-first {
    position: relative;
    display: inline-block;
  }

  .santa-hat {
    position: absolute;
    top: -12px;
    left: -5px;
    transform: rotate(-8deg);
    display: none;
    pointer-events: none;
    filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.25));
  }

  :global(body.is-december) .santa-hat {
    display: block;
  }

  .logo-cursor {
    color: var(--fg);
  }

  @media (prefers-reduced-motion: no-preference) {
    .logo-cursor {
      animation: cursor-blink 1s step-start infinite;
    }
  }

  @keyframes cursor-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .site-name {
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--fg-dim);
  }

  .site-tagline {
    font-size: 0.8rem;
    color: var(--fg-dim);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .search-trigger {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
    padding: 0.5rem 0.75rem;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--fg-dim);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    cursor: pointer;
    width: 100%;
    max-width: 320px;
    transition:
      border-color 0.1s,
      color 0.1s;
    text-align: left;
  }

  .search-trigger:hover {
    border-color: var(--border-active);
    color: var(--fg);
  }

  .search-trigger-prompt {
    flex-shrink: 0;
  }

  .search-trigger-label {
    flex: 1;
    opacity: 0.6;
  }

  .search-trigger-hint {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--fg-dim);
    border: 1px solid var(--border);
    padding: 0.1rem 0.3rem;
    line-height: 1.4;
    background: transparent;
    flex-shrink: 0;
  }

  .search-trigger-hint .mod {
    font-size: 1.2em;
    line-height: 1;
  }

  .search-trigger-hint .sep {
    margin: 0 0.25em;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    position: relative;
  }

  .site-footer {
    margin-top: auto;
    padding: 2rem;
    border-top: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--fg-dim);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .site-footer p {
    margin: 0;
  }

  .site-footer a {
    color: var(--fg);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .site-footer a:hover {
    color: var(--accent, var(--fg));
  }

  @media (hover: none) and (pointer: coarse) {
    .keybindings {
      display: none;
    }
  }

  .keybindings {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .keybindings li {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    white-space: nowrap;
  }

  .keybindings kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.1em 0.4em;
    border: 1px solid var(--border);
    border-radius: 3px;
    font-family: inherit;
    font-size: 0.8em;
    color: var(--fg);
    background: transparent;
    line-height: 1.4;
  }

  .keybindings kbd .mod {
    font-size: 1.2em;
    line-height: 1;
  }

  .keybindings kbd .sep {
    margin: 0 0.25em;
  }
</style>
