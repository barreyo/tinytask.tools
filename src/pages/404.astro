---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404" description="Page not found." noindex>
  <div class="not-found">
    <p class="code">404</p>
    <p class="message">page not found</p>
    <a href="/" class="home-link">← back to tt_</a>
  </div>
</Layout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    gap: 0.5rem;
  }

  .code {
    margin: 0;
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--fg);
    line-height: 1;
  }

  .message {
    margin: 0;
    font-size: 0.8rem;
    color: var(--fg-dim);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .home-link {
    margin-top: 1.5rem;
    font-size: 0.75rem;
    color: var(--fg-dim);
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border: 1px solid var(--border);
    padding: 0.5rem 1rem;
    transition:
      border-color 0.1s,
      color 0.1s;
  }

  .home-link:hover {
    border-color: var(--border-active);
    color: var(--fg);
  }
</style>
