---
// Fully client-side — file data never leaves the browser
---

<div class="nacha-tool">
  <!-- Security notice -->
  <div class="nacha-notice" role="note">
    <span class="nacha-notice-icon">⚑</span>
    This tool runs entirely in your browser. Your ACH data is never sent to any server.
  </div>

  <!-- Tab switcher -->
  <div class="nacha-tabs" role="tablist">
    <button
      id="tab-parse"
      class="tab-btn active"
      role="tab"
      aria-selected="true"
      aria-controls="panel-parse">parse</button
    >
    <button
      id="tab-generate"
      class="tab-btn"
      role="tab"
      aria-selected="false"
      aria-controls="panel-generate">generate</button
    >
  </div>

  <!-- ═══════ PARSE TAB ═══════ -->
  <div id="panel-parse" class="tab-panel" role="tabpanel" aria-labelledby="tab-parse">
    <!-- Input section -->
    <div class="input-section">
      <div class="section-header">
        <span class="section-label">nacha file input</span>
        <div class="section-actions">
          <button id="load-sample-btn" class="action-btn">load sample</button>
          <label class="action-btn" for="nacha-file-input">upload file</label>
          <input id="nacha-file-input" type="file" accept=".ach,.txt,.nacha" hidden />
          <button id="parse-clear-btn" class="action-btn">clear</button>
        </div>
      </div>
      <div id="drop-zone" class="drop-zone" role="region" aria-label="NACHA file drop zone">
        <textarea
          id="nacha-input"
          class="nacha-textarea"
          placeholder="Paste NACHA / ACH file contents here, or drop a .ach file…"
          spellcheck="false"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="off"
          rows="8"
          aria-label="NACHA file input"></textarea>
        <div id="drop-overlay" class="drop-overlay" hidden>
          <span>drop .ach file</span>
        </div>
      </div>
    </div>

    <!-- Validation status banner -->
    <div id="validation-status" class="validation-status" hidden role="status" aria-live="polite">
      <span id="status-icon" class="status-icon"></span>
      <span id="status-text" class="status-text"></span>
      <span id="status-detail" class="status-detail"></span>
    </div>

    <!-- Summary -->
    <div id="parse-summary" class="summary-section" hidden>
      <div class="section-header">
        <span class="section-label">summary</span>
      </div>
      <div id="summary-grid" class="summary-grid"></div>
    </div>

    <!-- Validation errors (shown before records so they're visible first) -->
    <div id="parse-errors" class="error-section" hidden>
      <div class="section-header">
        <span class="section-label error-label">validation issues</span>
        <span id="error-count" class="error-count"></span>
      </div>
      <ul id="error-list" class="error-list"></ul>
    </div>

    <!-- Highlighted view -->
    <div id="parse-output" class="output-section" hidden>
      <div class="section-header">
        <span class="section-label">parsed records</span>
        <div class="section-actions">
          <button id="copy-parsed-btn" class="action-btn">copy</button>
          <button id="download-parsed-btn" class="action-btn">download</button>
        </div>
      </div>
      <div id="records-view" class="records-view" aria-live="polite"></div>
    </div>
  </div>

  <!-- Field detail popover (shared between parse and generate tabs) -->
  <div id="field-tooltip" class="field-tooltip" hidden role="tooltip">
    <div class="field-tooltip-name" id="ft-name"></div>
    <div class="field-tooltip-body">
      <div class="field-tooltip-row">
        <span class="ft-label">value</span><span class="ft-value" id="ft-raw"></span>
      </div>
      <div class="field-tooltip-row" id="ft-interpreted-row" hidden>
        <span class="ft-label">meaning</span><span class="ft-value ft-meaning" id="ft-val"></span>
      </div>
      <div class="field-tooltip-row">
        <span class="ft-label">position</span><span class="ft-value" id="ft-pos"></span>
      </div>
      <div class="field-tooltip-desc" id="ft-desc"></div>
    </div>
  </div>

  <!-- Error hint popover -->
  <div id="error-hint-tooltip" class="error-hint-tooltip" hidden role="tooltip">
    <div class="error-hint-header">how to fix</div>
    <div class="error-hint-body" id="eht-body"></div>
  </div>

  <!-- ═══════ GENERATE TAB ═══════ -->
  <div id="panel-generate" class="tab-panel" role="tabpanel" aria-labelledby="tab-generate" hidden>
    <!-- File header fields -->
    <div class="gen-section">
      <div class="section-header">
        <span class="section-label">file header</span>
      </div>
      <div class="gen-fields">
        <div class="gen-field">
          <label for="gen-dest-routing">destination routing #</label>
          <input id="gen-dest-routing" type="text" maxlength="9" placeholder="076401251" />
        </div>
        <div class="gen-field">
          <label for="gen-dest-name">destination name</label>
          <input id="gen-dest-name" type="text" maxlength="23" placeholder="DEST BANK NAME" />
        </div>
        <div class="gen-field">
          <label for="gen-origin-routing">origin routing #</label>
          <input id="gen-origin-routing" type="text" maxlength="9" placeholder="076401251" />
        </div>
        <div class="gen-field">
          <label for="gen-origin-name">origin name</label>
          <input id="gen-origin-name" type="text" maxlength="23" placeholder="ORIGIN BANK NAME" />
        </div>
      </div>
    </div>

    <!-- Batches -->
    <div id="gen-batches" class="gen-batches"></div>

    <div class="gen-actions-row">
      <button id="gen-add-batch-btn" class="action-btn primary">+ add batch</button>
    </div>

    <!-- Preview -->
    <div class="gen-section">
      <div class="section-header">
        <span class="section-label">generated file preview</span>
        <div class="section-actions">
          <button id="gen-copy-btn" class="action-btn" disabled>copy</button>
          <button id="gen-download-btn" class="action-btn" disabled>download</button>
        </div>
      </div>
      <pre
        id="gen-preview"
        class="gen-preview"
        aria-live="polite">
        <span class="nacha-placeholder">fill in the fields above and add at least one batch with entries</span>
      </pre>
    </div>
  </div>
</div>

<script>
  import {
    generateNachaFile,
    SAMPLE_NACHA,
    type GeneratorInput,
    type GeneratorBatchInput,
    type GeneratorEntryInput,
  } from '../../lib/nacha';
  import { getDebounceMs } from '../../lib/worker-utils';

  let _cleanup: AbortController | undefined;

  function init() {
    _cleanup?.abort();
    _cleanup = new AbortController();

    const nachaInput = document.getElementById('nacha-input') as HTMLTextAreaElement;
    if (!nachaInput) return;

    // ── DOM refs ──
    const tabParse = document.getElementById('tab-parse') as HTMLButtonElement;
    const tabGenerate = document.getElementById('tab-generate') as HTMLButtonElement;
    const panelParse = document.getElementById('panel-parse') as HTMLDivElement;
    const panelGenerate = document.getElementById('panel-generate') as HTMLDivElement;
    const fileInput = document.getElementById('nacha-file-input') as HTMLInputElement;
    const dropZone = document.getElementById('drop-zone') as HTMLDivElement;
    const dropOverlay = document.getElementById('drop-overlay') as HTMLDivElement;
    const loadSampleBtn = document.getElementById('load-sample-btn') as HTMLButtonElement;
    const parseClearBtn = document.getElementById('parse-clear-btn') as HTMLButtonElement;
    const parseSummary = document.getElementById('parse-summary') as HTMLDivElement;
    const summaryGrid = document.getElementById('summary-grid') as HTMLDivElement;
    const parseOutput = document.getElementById('parse-output') as HTMLDivElement;
    const recordsView = document.getElementById('records-view') as HTMLDivElement;
    const parseErrors = document.getElementById('parse-errors') as HTMLDivElement;
    const errorList = document.getElementById('error-list') as HTMLUListElement;
    const copyParsedBtn = document.getElementById('copy-parsed-btn') as HTMLButtonElement;
    const downloadParsedBtn = document.getElementById('download-parsed-btn') as HTMLButtonElement;
    const validationStatus = document.getElementById('validation-status') as HTMLDivElement;
    const statusIcon = document.getElementById('status-icon') as HTMLSpanElement;
    const statusText = document.getElementById('status-text') as HTMLSpanElement;
    const statusDetail = document.getElementById('status-detail') as HTMLSpanElement;
    const errorCount = document.getElementById('error-count') as HTMLSpanElement;

    // Generate tab refs
    const genBatches = document.getElementById('gen-batches') as HTMLDivElement;
    const genAddBatchBtn = document.getElementById('gen-add-batch-btn') as HTMLButtonElement;
    const genPreview = document.getElementById('gen-preview') as HTMLPreElement;
    const genCopyBtn = document.getElementById('gen-copy-btn') as HTMLButtonElement;
    const genDownloadBtn = document.getElementById('gen-download-btn') as HTMLButtonElement;

    let currentRaw = '';
    let currentRequestId: string | null = null;

    // ── NACHA parse worker ────────────────────────────────────────────────────
    const nachaWorker = new Worker(
      new URL('../../workers/nacha-parser.worker.ts', import.meta.url),
      { type: 'module' },
    );

    nachaWorker.onmessage = (e: MessageEvent) => {
      const data = e.data;
      if (data.id !== currentRequestId) return;

      if (!data.ok) {
        validationStatus.hidden = true;
        parseSummary.hidden = true;
        parseErrors.hidden = true;
        parseOutput.hidden = true;
        return;
      }

      // Validation status banner
      validationStatus.hidden = false;
      validationStatus.className = `validation-status ${data.isValid ? 'status-valid' : 'status-invalid'}`;
      statusIcon.textContent = data.isValid ? '✓' : '✗';
      statusText.textContent = data.isValid ? 'valid nacha file' : 'invalid nacha file';
      statusDetail.textContent = data.statusDetail;

      // Summary
      summaryGrid.innerHTML = data.summaryHtml;
      parseSummary.hidden = false;

      // Errors
      if (data.errorCount > 0) {
        errorCount.textContent = `${data.errorCount}`;
        errorList.innerHTML = data.errorItemsHtml;
        parseErrors.hidden = false;
      } else {
        parseErrors.hidden = true;
      }

      // Records
      recordsView.innerHTML = data.recordsHtml;
      parseOutput.hidden = false;
    };

    // ── Tab switching ──
    function switchTab(tab: 'parse' | 'generate') {
      const isParse = tab === 'parse';
      tabParse.classList.toggle('active', isParse);
      tabGenerate.classList.toggle('active', !isParse);
      tabParse.setAttribute('aria-selected', String(isParse));
      tabGenerate.setAttribute('aria-selected', String(!isParse));
      panelParse.hidden = !isParse;
      panelGenerate.hidden = isParse;
    }

    tabParse.addEventListener('click', () => switchTab('parse'));
    tabGenerate.addEventListener('click', () => switchTab('generate'));

    // ── Helpers ──
    function escapeHtml(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    async function copyText(text: string, btn: HTMLButtonElement) {
      await navigator.clipboard.writeText(text);
      const orig = btn.textContent;
      btn.textContent = 'copied';
      setTimeout(() => {
        btn.textContent = orig;
      }, 1200);
    }

    function downloadFile(content: string, filename: string) {
      const blob = new Blob([content], { type: 'text/plain' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      a.click();
      URL.revokeObjectURL(url);
    }

    // ── Scroll to a line in the records view ──
    function scrollToLine(lineNum: number) {
      const el = recordsView.querySelector(`[data-line="${lineNum}"]`) as HTMLElement | null;
      if (el) {
        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        el.classList.add('rec-flash');
        setTimeout(() => el.classList.remove('rec-flash'), 1500);
      }
    }

    // ── Parse & display (via worker) ─────────────────────────────────────────
    function doParse() {
      const raw = nachaInput.value.replace(/^\n+/, '').replace(/\n+$/, '');
      if (!raw.trim()) {
        currentRequestId = null;
        parseSummary.hidden = true;
        parseOutput.hidden = true;
        parseErrors.hidden = true;
        validationStatus.hidden = true;
        currentRaw = '';
        return;
      }

      currentRaw = raw;
      const id = crypto.randomUUID();
      currentRequestId = id;
      nachaWorker.postMessage({ id, raw });
    }

    // Delegated click handler for error line buttons
    errorList.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.error-line-btn') as HTMLElement | null;
      if (btn?.dataset.gotoLine) {
        scrollToLine(parseInt(btn.dataset.gotoLine, 10));
      }
    });

    let debounceTimer: ReturnType<typeof setTimeout>;
    nachaInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(doParse, getDebounceMs(nachaInput.value.length));
    });

    // File upload / drag-drop
    fileInput.addEventListener('change', () => {
      const file = fileInput.files?.[0];
      if (!file) return;
      file.text().then((text) => {
        nachaInput.value = text;
        doParse();
      });
      fileInput.value = '';
    });

    let dragCounter = 0;
    dropZone.addEventListener('dragenter', (e) => {
      e.preventDefault();
      dragCounter++;
      dropOverlay.hidden = false;
    });
    dropZone.addEventListener('dragleave', () => {
      dragCounter--;
      if (dragCounter <= 0) {
        dragCounter = 0;
        dropOverlay.hidden = true;
      }
    });
    dropZone.addEventListener('dragover', (e) => e.preventDefault());
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dragCounter = 0;
      dropOverlay.hidden = true;
      const file = e.dataTransfer?.files[0];
      if (!file) return;
      file.text().then((text) => {
        nachaInput.value = text;
        doParse();
      });
    });

    loadSampleBtn.addEventListener('click', () => {
      nachaInput.value = SAMPLE_NACHA;
      doParse();
    });

    parseClearBtn.addEventListener('click', () => {
      nachaInput.value = '';
      validationStatus.hidden = true;
      doParse();
      nachaInput.focus();
    });

    copyParsedBtn.addEventListener('click', () => copyText(currentRaw, copyParsedBtn));
    downloadParsedBtn.addEventListener('click', () => {
      if (currentRaw) downloadFile(currentRaw, 'nacha-file.ach');
    });

    // ══════════════════════════════════════════════════════════════════
    //  GENERATE TAB
    // ══════════════════════════════════════════════════════════════════

    interface BatchState {
      entries: EntryState[];
    }
    interface EntryState {
      id: number;
    }

    let batchStates: BatchState[] = [];
    let entryIdCounter = 0;

    function createEntryHtml(batchIdx: number, entryId: number): string {
      const prefix = `gen-b${batchIdx}-e${entryId}`;
      return `<div class="gen-entry" data-entry-id="${entryId}">
      <div class="gen-entry-header">
        <span class="section-label">entry</span>
        <button class="action-btn remove-entry-btn" data-batch="${batchIdx}" data-entry="${entryId}">remove</button>
      </div>
      <div class="gen-fields">
        <div class="gen-field">
          <label for="${prefix}-tc">transaction code</label>
          <select id="${prefix}-tc" class="gen-select">
            <option value="22">22 — Checking Credit</option>
            <option value="27">27 — Checking Debit</option>
            <option value="32">32 — Savings Credit</option>
            <option value="37">37 — Savings Debit</option>
            <option value="23">23 — Checking Credit Prenote</option>
            <option value="28">28 — Checking Debit Prenote</option>
            <option value="33">33 — Savings Credit Prenote</option>
            <option value="38">38 — Savings Debit Prenote</option>
          </select>
        </div>
        <div class="gen-field">
          <label for="${prefix}-routing">routing number</label>
          <input id="${prefix}-routing" type="text" maxlength="9" placeholder="091012981" />
        </div>
        <div class="gen-field">
          <label for="${prefix}-account">account number</label>
          <input id="${prefix}-account" type="text" maxlength="17" placeholder="1234567890" />
        </div>
        <div class="gen-field">
          <label for="${prefix}-amount">amount (cents)</label>
          <input id="${prefix}-amount" type="number" min="0" placeholder="100000" />
        </div>
        <div class="gen-field">
          <label for="${prefix}-name">receiver name</label>
          <input id="${prefix}-name" type="text" maxlength="22" placeholder="JOHN DOE" />
        </div>
        <div class="gen-field">
          <label for="${prefix}-id">identification # (optional)</label>
          <input id="${prefix}-id" type="text" maxlength="15" placeholder="" />
        </div>
        <div class="gen-field gen-field--wide">
          <label for="${prefix}-addenda">addenda info (optional)</label>
          <input id="${prefix}-addenda" type="text" maxlength="80" placeholder="Payment for invoice 12345" />
        </div>
      </div>
    </div>`;
    }

    function createBatchHtml(batchIdx: number): string {
      return `<div class="gen-batch" data-batch="${batchIdx}">
      <div class="gen-batch-header">
        <span class="section-label">batch ${batchIdx + 1}</span>
        <button class="action-btn remove-batch-btn" data-batch="${batchIdx}">remove batch</button>
      </div>
      <div class="gen-fields">
        <div class="gen-field">
          <label for="gen-b${batchIdx}-scc">service class code</label>
          <select id="gen-b${batchIdx}-scc" class="gen-select">
            <option value="200">200 — Mixed</option>
            <option value="220">220 — Credits Only</option>
            <option value="225">225 — Debits Only</option>
          </select>
        </div>
        <div class="gen-field">
          <label for="gen-b${batchIdx}-company">company name</label>
          <input id="gen-b${batchIdx}-company" type="text" maxlength="16" placeholder="ACME CORP" />
        </div>
        <div class="gen-field">
          <label for="gen-b${batchIdx}-companyid">company ID</label>
          <input id="gen-b${batchIdx}-companyid" type="text" maxlength="10" placeholder="1234567890" />
        </div>
        <div class="gen-field">
          <label for="gen-b${batchIdx}-sec">SEC code</label>
          <select id="gen-b${batchIdx}-sec" class="gen-select">
            <option value="PPD">PPD — Prearranged Payment</option>
            <option value="CCD">CCD — Corporate Credit/Debit</option>
            <option value="WEB">WEB — Internet/Mobile</option>
            <option value="TEL">TEL — Telephone</option>
            <option value="CTX">CTX — Corporate Trade</option>
          </select>
        </div>
        <div class="gen-field">
          <label for="gen-b${batchIdx}-desc">entry description</label>
          <input id="gen-b${batchIdx}-desc" type="text" maxlength="10" placeholder="PAYROLL" />
        </div>
        <div class="gen-field">
          <label for="gen-b${batchIdx}-date">effective date (YYMMDD)</label>
          <input id="gen-b${batchIdx}-date" type="text" maxlength="6" placeholder="260407" />
        </div>
      </div>
      <div class="gen-entries" id="gen-b${batchIdx}-entries"></div>
      <div class="gen-actions-row">
        <button class="action-btn add-entry-btn" data-batch="${batchIdx}">+ add entry</button>
      </div>
    </div>`;
    }

    function addBatch() {
      const batchIdx = batchStates.length;
      batchStates.push({ entries: [] });
      genBatches.insertAdjacentHTML('beforeend', createBatchHtml(batchIdx));
      addEntry(batchIdx);
    }

    function addEntry(batchIdx: number) {
      const entryId = entryIdCounter++;
      batchStates[batchIdx].entries.push({ id: entryId });
      const container = document.getElementById(`gen-b${batchIdx}-entries`);
      if (container) {
        container.insertAdjacentHTML('beforeend', createEntryHtml(batchIdx, entryId));
      }
    }

    function removeBatch(batchIdx: number) {
      const el = genBatches.querySelector(`[data-batch="${batchIdx}"]`);
      if (el) el.remove();
      batchStates[batchIdx] = null!;
    }

    function removeEntry(batchIdx: number, entryId: number) {
      const batch = batchStates[batchIdx];
      if (!batch) return;
      batch.entries = batch.entries.filter((e) => e.id !== entryId);
      const el = genBatches.querySelector(`[data-entry-id="${entryId}"]`);
      if (el) el.remove();
    }

    // Delegated click handlers for dynamic buttons
    genBatches.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains('add-entry-btn')) {
        const bi = parseInt(target.dataset.batch!, 10);
        addEntry(bi);
      } else if (target.classList.contains('remove-entry-btn')) {
        const bi = parseInt(target.dataset.batch!, 10);
        const ei = parseInt(target.dataset.entry!, 10);
        removeEntry(bi, ei);
        updatePreview();
      } else if (target.classList.contains('remove-batch-btn')) {
        const bi = parseInt(target.dataset.batch!, 10);
        removeBatch(bi);
        updatePreview();
      }
    });

    genAddBatchBtn.addEventListener('click', () => {
      addBatch();
      updatePreview();
    });

    function getInputVal(id: string): string {
      return (document.getElementById(id) as HTMLInputElement | HTMLSelectElement)?.value ?? '';
    }

    function gatherInput(): GeneratorInput | null {
      const destRouting = getInputVal('gen-dest-routing').trim();
      const originRouting = getInputVal('gen-origin-routing').trim();
      if (!destRouting || !originRouting) return null;

      const batches: GeneratorBatchInput[] = [];
      for (let bi = 0; bi < batchStates.length; bi++) {
        const bs = batchStates[bi];
        if (!bs) continue;
        const companyName = getInputVal(`gen-b${bi}-company`).trim();
        const companyId = getInputVal(`gen-b${bi}-companyid`).trim();
        if (!companyName || !companyId) continue;

        const entries: GeneratorEntryInput[] = [];
        for (const es of bs.entries) {
          const prefix = `gen-b${bi}-e${es.id}`;
          const routing = getInputVal(`${prefix}-routing`).trim();
          const account = getInputVal(`${prefix}-account`).trim();
          const amountStr = getInputVal(`${prefix}-amount`).trim();
          const name = getInputVal(`${prefix}-name`).trim();
          if (!routing || !account || !amountStr || !name) continue;
          entries.push({
            transactionCode: getInputVal(`${prefix}-tc`),
            routingNumber: routing,
            accountNumber: account,
            amount: parseInt(amountStr, 10) || 0,
            receiverName: name,
            identificationNumber: getInputVal(`${prefix}-id`).trim() || undefined,
            addendaInfo: getInputVal(`${prefix}-addenda`).trim() || undefined,
          });
        }
        if (entries.length === 0) continue;

        batches.push({
          serviceClassCode: getInputVal(`gen-b${bi}-scc`),
          companyName,
          companyIdentification: companyId,
          secCode: getInputVal(`gen-b${bi}-sec`),
          companyEntryDescription: getInputVal(`gen-b${bi}-desc`).trim() || 'PAYMENT',
          effectiveEntryDate: getInputVal(`gen-b${bi}-date`).trim(),
          entries,
        });
      }

      if (batches.length === 0) return null;

      return {
        immediateDestination: destRouting,
        immediateOrigin: originRouting,
        destinationName: getInputVal('gen-dest-name').trim(),
        originName: getInputVal('gen-origin-name').trim(),
        batches,
      };
    }

    let generatedContent = '';

    // Lightweight record-line renderer for the generate-tab live preview.
    // The parse tab's rich rendering (with field tooltips + error markers) is
    // handled in the nacha-parser worker; this simpler version is fine here.
    function renderLine(line: string, lineNum: number): string {
      if (!line || line.length === 0) return '';
      const isPadding = /^9+$/.test(line);
      if (isPadding) {
        return `<div class="record-line rec-padding" data-line="${lineNum}"><span class="line-num">${lineNum}</span><span class="line-content">${escapeHtml(line)}</span></div>`;
      }
      const type = line[0];
      const LABELS: Record<string, string> = {
        '1': 'File Header',
        '5': 'Batch Header',
        '6': 'Entry Detail',
        '7': 'Addenda',
        '8': 'Batch Control',
        '9': 'File Control',
      };
      const label = LABELS[type] || 'Unknown';
      return `<div class="record-line rec-${type}" data-line="${lineNum}"><span class="line-num">${lineNum}</span><span class="rec-badge">${type}</span><span class="rec-label">${label}</span><span class="line-fields"><span class="field-span">${escapeHtml(line)}</span></span></div>`;
    }

    function updatePreview() {
      const input = gatherInput();
      if (!input) {
        genPreview.innerHTML =
          '<span class="nacha-placeholder">fill in the fields above and add at least one batch with entries</span>';
        genCopyBtn.disabled = true;
        genDownloadBtn.disabled = true;
        generatedContent = '';
        return;
      }

      try {
        generatedContent = generateNachaFile(input);
        const lines = generatedContent.split('\n');
        let html = '';
        for (let i = 0; i < lines.length; i++) {
          html += renderLine(lines[i], i + 1);
        }
        genPreview.innerHTML = html;
        genCopyBtn.disabled = false;
        genDownloadBtn.disabled = false;
      } catch (err) {
        genPreview.innerHTML = `<span class="gen-error">${escapeHtml((err as Error).message)}</span>`;
        genCopyBtn.disabled = true;
        genDownloadBtn.disabled = true;
        generatedContent = '';
      }
    }

    // Live update on any input change in the generate panel
    panelGenerate.addEventListener('input', () => {
      clearTimeout(genDebounce);
      genDebounce = setTimeout(updatePreview, 250);
    });
    panelGenerate.addEventListener('change', () => {
      clearTimeout(genDebounce);
      genDebounce = setTimeout(updatePreview, 100);
    });
    let genDebounce: ReturnType<typeof setTimeout>;

    genCopyBtn.addEventListener('click', () => copyText(generatedContent, genCopyBtn));
    genDownloadBtn.addEventListener('click', () => {
      if (generatedContent) downloadFile(generatedContent, 'generated.ach');
    });

    // Seed with one batch + one entry
    addBatch();

    // ── Field detail tooltip ──
    const fieldTooltip = document.getElementById('field-tooltip') as HTMLDivElement;
    const ftName = document.getElementById('ft-name') as HTMLDivElement;
    const ftRaw = document.getElementById('ft-raw') as HTMLSpanElement;
    const ftVal = document.getElementById('ft-val') as HTMLSpanElement;
    const ftInterpretedRow = document.getElementById('ft-interpreted-row') as HTMLDivElement;
    const ftPos = document.getElementById('ft-pos') as HTMLSpanElement;
    const ftDesc = document.getElementById('ft-desc') as HTMLDivElement;

    let tooltipTarget: HTMLElement | null = null;

    function showFieldTooltip(span: HTMLElement) {
      const name = span.dataset.fieldName;
      if (!name) return;

      tooltipTarget = span;
      ftName.textContent = name;

      const rawVal = span.dataset.fieldRaw ?? '';
      ftRaw.textContent = rawVal.trim() || '(empty)';

      const fmtVal = span.dataset.fieldVal ?? '';
      if (fmtVal) {
        ftVal.textContent = fmtVal;
        ftInterpretedRow.hidden = false;
      } else {
        ftInterpretedRow.hidden = true;
      }

      ftPos.textContent = `chars ${span.dataset.fieldPos ?? ''}`;

      const desc = span.dataset.fieldDesc ?? '';
      if (desc) {
        ftDesc.textContent = desc;
        ftDesc.hidden = false;
      } else {
        ftDesc.hidden = true;
      }

      fieldTooltip.hidden = false;
      positionTooltip(span);
    }

    function positionTooltip(span: HTMLElement) {
      const rect = span.getBoundingClientRect();
      const ttRect = fieldTooltip.getBoundingClientRect();
      const vw = window.innerWidth;
      const vh = window.innerHeight;

      let top = rect.bottom + 6;
      let left = rect.left + rect.width / 2 - ttRect.width / 2;

      if (top + ttRect.height > vh - 8) {
        top = rect.top - ttRect.height - 6;
      }

      if (left < 8) left = 8;
      if (left + ttRect.width > vw - 8) left = vw - 8 - ttRect.width;

      fieldTooltip.style.top = `${top}px`;
      fieldTooltip.style.left = `${left}px`;
    }

    function hideFieldTooltip() {
      fieldTooltip.hidden = true;
      tooltipTarget = null;
    }

    document.addEventListener(
      'mouseover',
      (e) => {
        const span = (e.target as HTMLElement).closest(
          '.field-span[data-field-name]',
        ) as HTMLElement | null;
        if (span) {
          showFieldTooltip(span);
        } else if (tooltipTarget && !(e.target as HTMLElement).closest('#field-tooltip')) {
          hideFieldTooltip();
        }
      },
      { signal: _cleanup!.signal },
    );

    document.addEventListener(
      'mouseout',
      (e) => {
        const related = e.relatedTarget as HTMLElement | null;
        if (
          tooltipTarget &&
          !related?.closest('.field-span[data-field-name]') &&
          !related?.closest('#field-tooltip')
        ) {
          hideFieldTooltip();
        }
      },
      { signal: _cleanup!.signal },
    );

    document.addEventListener('scroll', hideFieldTooltip, {
      capture: true,
      signal: _cleanup!.signal,
    });

    // ── Error hint tooltip ──
    const errorHintTooltip = document.getElementById('error-hint-tooltip') as HTMLDivElement;
    const ehtBody = document.getElementById('eht-body') as HTMLDivElement;
    let errorHintTarget: HTMLElement | null = null;

    function showErrorHint(li: HTMLElement) {
      const hint = li.dataset.errorHint;
      if (!hint) return;
      errorHintTarget = li;
      ehtBody.textContent = hint;
      errorHintTooltip.hidden = false;
      positionErrorHint(li);
    }

    function positionErrorHint(el: HTMLElement) {
      const rect = el.getBoundingClientRect();
      const ttRect = errorHintTooltip.getBoundingClientRect();
      const vw = window.innerWidth;
      const vh = window.innerHeight;

      let top = rect.bottom + 4;
      let left = rect.left;

      if (top + ttRect.height > vh - 8) {
        top = rect.top - ttRect.height - 4;
      }
      if (left < 8) left = 8;
      if (left + ttRect.width > vw - 8) left = vw - 8 - ttRect.width;

      errorHintTooltip.style.top = `${top}px`;
      errorHintTooltip.style.left = `${left}px`;
    }

    function hideErrorHint() {
      errorHintTooltip.hidden = true;
      errorHintTarget = null;
    }

    errorList.addEventListener('mouseover', (e) => {
      const li = (e.target as HTMLElement).closest('li[data-error-hint]') as HTMLElement | null;
      if (li && li !== errorHintTarget) {
        showErrorHint(li);
      }
    });

    errorList.addEventListener('mouseleave', () => {
      hideErrorHint();
    });

    errorList.addEventListener('mouseout', (e) => {
      const related = e.relatedTarget as HTMLElement | null;
      if (
        errorHintTarget &&
        !related?.closest('li[data-error-hint]') &&
        !related?.closest('#error-hint-tooltip')
      ) {
        hideErrorHint();
      }
    });

    document.addEventListener('scroll', hideErrorHint, { capture: true, signal: _cleanup!.signal });
  } // end init

  document.addEventListener('astro:page-load', init);
</script>

