---
// No server-side logic needed — fully client-side
---

<div class="pw-tool">
  <!-- Output display -->
  <div class="output-section">
    <div class="output-header">
      <span class="section-label">generated password</span>
      <div class="output-actions">
        <button class="action-btn" id="copy-btn" disabled>copy</button>
        <button class="action-btn primary" id="generate-btn">generate</button>
      </div>
    </div>
    <div
      class="password-display"
      id="password-display"
      aria-label="Generated password"
      aria-live="polite"
    >
      <span class="password-placeholder">press generate or Ctrl+Enter</span>
    </div>

    <!-- Strength bar -->
    <div class="strength-bar-wrap">
      <div class="strength-bar" id="strength-bar">
        <div class="strength-fill" id="strength-fill" data-level="0"></div>
      </div>
      <span class="strength-label" id="strength-label"></span>
      <span class="entropy-label" id="entropy-label"></span>
    </div>
  </div>

  <!-- Controls -->
  <div class="controls-section">
    <div class="controls-header">
      <span class="section-label">options</span>
    </div>
    <div class="controls-body">
      <!-- Length -->
      <div class="length-row">
        <label class="field-label" for="length-slider">Length</label>
        <input type="range" id="length-slider" min="4" max="128" value="20" class="length-slider" />
        <input type="number" id="length-input" min="4" max="128" value="20" class="length-number" />
      </div>

      <!-- Character sets -->
      <div class="charset-grid">
        <label class="check-label">
          <input type="checkbox" id="chk-upper" checked />
          <span>Uppercase (A–Z)</span>
        </label>
        <label class="check-label">
          <input type="checkbox" id="chk-lower" checked />
          <span>Lowercase (a–z)</span>
        </label>
        <label class="check-label">
          <input type="checkbox" id="chk-digits" checked />
          <span>Digits (0–9)</span>
        </label>
        <label class="check-label">
          <input type="checkbox" id="chk-symbols" checked />
          <span>Symbols (!@#$…)</span>
        </label>
        <label class="check-label">
          <input type="checkbox" id="chk-ambiguous" />
          <span>Exclude ambiguous (0, O, l, 1, I)</span>
        </label>
        <label class="check-label">
          <input type="checkbox" id="chk-require-each" checked />
          <span>Require at least one from each set</span>
        </label>
      </div>

      <!-- Custom characters -->
      <div class="custom-chars-row">
        <label class="field-label" for="custom-chars">Custom characters (added to pool)</label>
        <input
          type="text"
          id="custom-chars"
          class="custom-chars-input"
          placeholder="e.g. ñéü"
          spellcheck="false"
        />
      </div>

      <!-- Batch mode -->
      <div class="batch-row">
        <label class="field-label" for="batch-count">Batch count</label>
        <input type="number" id="batch-count" min="1" max="50" value="1" class="length-number" />
        <button class="action-btn" id="batch-btn">generate batch</button>
      </div>
    </div>
  </div>

  <!-- Batch results -->
  <div class="batch-section" id="batch-section" hidden>
    <div class="batch-header">
      <span class="section-label">batch</span>
      <div class="batch-actions">
        <button class="action-btn" id="copy-all-btn">copy all</button>
        <button class="action-btn" id="clear-batch-btn">clear</button>
      </div>
    </div>
    <div id="batch-list" class="batch-list" aria-live="polite"></div>
  </div>

  <!-- History -->
  <div class="history-section">
    <div class="history-header">
      <span class="section-label">history</span>
      <button class="action-btn" id="clear-history-btn">clear</button>
    </div>
    <div id="history-list" class="history-list" aria-live="polite"></div>
    <p id="history-empty" class="history-empty">no history yet</p>
  </div>
</div>

<script>
  import { generatePassword, estimateStrength } from '../../lib/password-generator';
  import type { PasswordOptions } from '../../lib/password-generator';

  const passwordDisplay = document.getElementById('password-display') as HTMLDivElement;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;
  const strengthFill = document.getElementById('strength-fill') as HTMLDivElement;
  const strengthLabel = document.getElementById('strength-label') as HTMLSpanElement;
  const entropyLabel = document.getElementById('entropy-label') as HTMLSpanElement;

  const lengthSlider = document.getElementById('length-slider') as HTMLInputElement;
  const lengthInput = document.getElementById('length-input') as HTMLInputElement;
  const chkUpper = document.getElementById('chk-upper') as HTMLInputElement;
  const chkLower = document.getElementById('chk-lower') as HTMLInputElement;
  const chkDigits = document.getElementById('chk-digits') as HTMLInputElement;
  const chkSymbols = document.getElementById('chk-symbols') as HTMLInputElement;
  const chkAmbiguous = document.getElementById('chk-ambiguous') as HTMLInputElement;
  const chkRequireEach = document.getElementById('chk-require-each') as HTMLInputElement;
  const customCharsInput = document.getElementById('custom-chars') as HTMLInputElement;

  const batchCountInput = document.getElementById('batch-count') as HTMLInputElement;
  const batchBtn = document.getElementById('batch-btn') as HTMLButtonElement;
  const batchSection = document.getElementById('batch-section') as HTMLDivElement;
  const batchList = document.getElementById('batch-list') as HTMLDivElement;
  const copyAllBtn = document.getElementById('copy-all-btn') as HTMLButtonElement;
  const clearBatchBtn = document.getElementById('clear-batch-btn') as HTMLButtonElement;

  const historyList = document.getElementById('history-list') as HTMLDivElement;
  const historyEmpty = document.getElementById('history-empty') as HTMLParagraphElement;
  const clearHistoryBtn = document.getElementById('clear-history-btn') as HTMLButtonElement;

  const STORAGE_KEY = 'tt_password_history';
  const MAX_HISTORY = 10;

  let currentPassword = '';

  // ── Sync length slider ↔ input ─────────────────────────────────────────────
  lengthSlider.addEventListener('input', () => {
    lengthInput.value = lengthSlider.value;
  });

  lengthInput.addEventListener('input', () => {
    const v = Math.max(4, Math.min(128, parseInt(lengthInput.value) || 4));
    lengthSlider.value = String(v);
    lengthInput.value = String(v);
  });

  // ── Build options ──────────────────────────────────────────────────────────
  function getOptions(): PasswordOptions {
    return {
      length: parseInt(lengthSlider.value) || 20,
      uppercase: chkUpper.checked,
      lowercase: chkLower.checked,
      digits: chkDigits.checked,
      symbols: chkSymbols.checked,
      customChars: customCharsInput.value,
      excludeAmbiguous: chkAmbiguous.checked,
      requireEachSet: chkRequireEach.checked,
    };
  }

  // ── Generate ───────────────────────────────────────────────────────────────
  function generate(): void {
    const opts = getOptions();
    if (!opts.uppercase && !opts.lowercase && !opts.digits && !opts.symbols && !opts.customChars) {
      return;
    }

    let pw: string;
    try {
      pw = generatePassword(opts);
    } catch {
      return;
    }

    currentPassword = pw;
    passwordDisplay.innerHTML = '';
    const code = document.createElement('code');
    code.textContent = pw;
    passwordDisplay.appendChild(code);
    copyBtn.disabled = false;

    const strength = estimateStrength(pw);
    strengthFill.dataset.level = String(strength.level);
    strengthLabel.textContent = strength.label;
    entropyLabel.textContent = `${Math.round(strength.bits)} bits`;

    appendHistory(pw);
  }

  generateBtn.addEventListener('click', generate);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) {
      e.preventDefault();
      generate();
    }
  });

  copyBtn.addEventListener('click', async () => {
    if (!currentPassword) return;
    await navigator.clipboard.writeText(currentPassword);
    copyBtn.textContent = 'copied';
    setTimeout(() => (copyBtn.textContent = 'copy'), 1200);
  });

  // ── Batch ──────────────────────────────────────────────────────────────────
  function makeCopyBtn(pw: string): HTMLButtonElement {
    const btn = document.createElement('button');
    btn.className = 'action-btn batch-copy-btn';
    btn.textContent = 'copy';
    btn.addEventListener('click', async () => {
      await navigator.clipboard.writeText(pw);
      btn.textContent = 'copied';
      setTimeout(() => (btn.textContent = 'copy'), 1200);
    });
    return btn;
  }

  batchBtn.addEventListener('click', () => {
    const opts = getOptions();
    const count = Math.max(1, Math.min(50, parseInt(batchCountInput.value) || 1));
    const passwords: string[] = [];

    for (let i = 0; i < count; i++) {
      try {
        passwords.push(generatePassword(opts));
      } catch {
        break;
      }
    }

    batchSection.hidden = false;
    batchList.innerHTML = '';
    passwords.forEach((pw, i) => {
      const row = document.createElement('div');
      row.className = 'batch-row-item';

      const num = document.createElement('span');
      num.className = 'batch-num';
      num.textContent = String(i + 1);

      const code = document.createElement('code');
      code.className = 'batch-pw';
      code.textContent = pw;

      row.appendChild(num);
      row.appendChild(code);
      row.appendChild(makeCopyBtn(pw));
      batchList.appendChild(row);
    });
  });

  copyAllBtn.addEventListener('click', async () => {
    const codes = [...batchList.querySelectorAll<HTMLElement>('.batch-pw')].map(
      (c) => c.textContent ?? '',
    );
    await navigator.clipboard.writeText(codes.join('\n'));
    copyAllBtn.textContent = 'copied';
    setTimeout(() => (copyAllBtn.textContent = 'copy all'), 1200);
  });

  clearBatchBtn.addEventListener('click', () => {
    batchList.innerHTML = '';
    batchSection.hidden = true;
  });

  // ── History ────────────────────────────────────────────────────────────────
  function loadHistory(): string[] {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) ?? '[]');
    } catch {
      return [];
    }
  }

  function saveHistory(entries: string[]): void {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(entries.slice(0, MAX_HISTORY)));
    } catch {}
  }

  function appendHistory(pw: string): void {
    const entries = [pw, ...loadHistory().filter((e) => e !== pw)].slice(0, MAX_HISTORY);
    saveHistory(entries);
    renderHistory(entries);
  }

  function renderHistory(entries: string[]): void {
    historyList.innerHTML = '';
    if (entries.length === 0) {
      historyEmpty.hidden = false;
      return;
    }
    historyEmpty.hidden = true;
    entries.forEach((pw) => {
      const item = document.createElement('div');
      item.className = 'history-item';

      const code = document.createElement('code');
      code.className = 'history-pw';
      code.textContent = pw;

      const btn = document.createElement('button');
      btn.className = 'action-btn hist-copy-btn';
      btn.textContent = 'copy';
      btn.addEventListener('click', async () => {
        await navigator.clipboard.writeText(pw);
        btn.textContent = 'copied';
        setTimeout(() => (btn.textContent = 'copy'), 1200);
      });

      item.appendChild(code);
      item.appendChild(btn);
      historyList.appendChild(item);
    });
  }

  clearHistoryBtn.addEventListener('click', () => {
    saveHistory([]);
    renderHistory([]);
  });

  renderHistory(loadHistory());
</script>

<style>
  .pw-tool {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── Output section ─────────────────────────────────────────────────────── */
  .output-section {
    border: 1px solid var(--border);
  }

  .output-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .output-actions {
    display: flex;
    gap: 0.4rem;
  }

  .password-display {
    padding: 1rem 0.75rem;
    min-height: 3rem;
    display: flex;
    align-items: center;
    word-break: break-all;
  }

  .password-display code {
    font-family: inherit;
    font-size: 1.1rem;
    letter-spacing: 0.04em;
    color: var(--fg);
  }

  .password-placeholder {
    font-size: 0.8rem;
    color: var(--fg-dim);
    letter-spacing: 0.04em;
  }

  /* ── Strength bar ───────────────────────────────────────────────────────── */
  .strength-bar-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    border-top: 1px solid var(--border);
  }

  .strength-bar {
    flex: 1;
    height: 6px;
    background: var(--border);
    overflow: hidden;
  }

  .strength-fill {
    height: 100%;
    width: 0%;
    transition:
      width 0.2s,
      background 0.2s;
  }

  .strength-fill[data-level='0'] {
    width: 0%;
    background: transparent;
  }
  .strength-fill[data-level='1'] {
    width: 25%;
    background: var(--fg-dim);
    opacity: 0.5;
  }
  .strength-fill[data-level='2'] {
    width: 50%;
    background: var(--fg-dim);
    opacity: 0.7;
  }
  .strength-fill[data-level='3'] {
    width: 75%;
    background: var(--fg);
    opacity: 0.6;
  }
  .strength-fill[data-level='4'] {
    width: 100%;
    background: var(--fg);
  }

  .strength-label {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-dim);
    min-width: 6rem;
  }

  .entropy-label {
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: var(--fg-dim);
    flex-shrink: 0;
  }

  /* ── Controls section ───────────────────────────────────────────────────── */
  .controls-section {
    border: 1px solid var(--border);
  }

  .controls-header {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .controls-body {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Length row ─────────────────────────────────────────────────────────── */
  .length-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .length-slider {
    flex: 1;
    min-width: 120px;
    accent-color: var(--fg);
  }

  .length-number {
    background: none;
    border: 1px solid var(--border);
    color: var(--fg);
    font-family: inherit;
    font-size: 0.85rem;
    padding: 0.3rem 0.5rem;
    width: 4rem;
    text-align: center;
  }

  .length-number:focus {
    outline: 1px solid var(--border-active);
  }

  /* ── Charset grid ───────────────────────────────────────────────────────── */
  .charset-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.5rem;
  }

  .check-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    color: var(--fg-dim);
    cursor: pointer;
  }

  .check-label input[type='checkbox'] {
    cursor: pointer;
  }

  /* ── Custom chars ───────────────────────────────────────────────────────── */
  .custom-chars-row {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .custom-chars-input {
    background: none;
    border: 1px solid var(--border);
    color: var(--fg);
    font-family: inherit;
    font-size: 0.85rem;
    padding: 0.35rem 0.5rem;
    width: 100%;
    box-sizing: border-box;
  }

  .custom-chars-input:focus {
    outline: 1px solid var(--border-active);
  }

  /* ── Batch row ──────────────────────────────────────────────────────────── */
  .batch-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* ── Batch section ──────────────────────────────────────────────────────── */
  .batch-section {
    border: 1px solid var(--border);
  }

  .batch-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .batch-actions {
    display: flex;
    gap: 0.4rem;
  }

  .batch-list {
    max-height: 320px;
    overflow-y: auto;
  }

  :global(.batch-row-item) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.4rem 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  :global(.batch-row-item:last-child) {
    border-bottom: none;
  }

  :global(.batch-num) {
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--fg-dim);
    min-width: 1.5rem;
    text-align: right;
    flex-shrink: 0;
  }

  :global(.batch-pw) {
    flex: 1;
    font-family: inherit;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--fg);
    word-break: break-all;
    min-width: 0;
  }

  /* ── History section ────────────────────────────────────────────────────── */
  .history-section {
    border: 1px solid var(--border);
  }

  .history-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .history-list {
    max-height: 280px;
    overflow-y: auto;
  }

  .history-empty {
    margin: 0;
    padding: 0.75rem;
    font-size: 0.75rem;
    color: var(--fg-dim);
    letter-spacing: 0.04em;
  }

  :global(.history-item) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.4rem 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  :global(.history-item:last-child) {
    border-bottom: none;
  }

  :global(.history-pw) {
    flex: 1;
    font-family: inherit;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: var(--fg);
    word-break: break-all;
    min-width: 0;
  }

  /* ── Shared ─────────────────────────────────────────────────────────────── */
  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }

  .field-label {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-dim);
  }

  .action-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--fg-dim);
    font-family: inherit;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    transition:
      border-color 0.1s,
      color 0.1s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .action-btn:hover:not(:disabled) {
    border-color: var(--border-active);
    color: var(--fg);
  }

  .action-btn:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .action-btn.primary {
    border-color: var(--fg-dim);
    color: var(--fg);
  }

  .action-btn.primary:hover {
    border-color: var(--border-active);
  }
</style>
